  "keyFeatures": [
    "Peripheral Driver API (C) for GPIO, UART, SPI, I2C, I2S, ADC, DMA, RTC, WDT, TRNG, and more",
    "Board Support Packages (BSPs) for official Analog Devices evaluation kits",
    "GCC-based toolchain with GNU Make build system",
    "Visual Studio Code, Eclipse, Keil MDK, and IAR Embedded Workbench IDE support",
    "Cordio Bluetooth Low Energy (BLE) stack for BLE-enabled MCUs",
    "FreeRTOS real-time OS support for all parts",
    "USB support via MAXUSB and TinyUSB libraries",
    "SDHC/FatFS library for SD card file system support",
    "CMSIS-DSP library for hardware-accelerated signal processing",
    "MAX78000/MAX78002 AI/CNN accelerator support",
    "OpenOCD-based flash and debug integration",
    "50+ example projects per supported microcontroller"
  ],
  "publicApiSurface": [
    "MXC_GPIO_Config / MXC_GPIO_OutSet / MXC_GPIO_InGet",
    "MXC_UART_Init / MXC_UART_Write / MXC_UART_Read",
