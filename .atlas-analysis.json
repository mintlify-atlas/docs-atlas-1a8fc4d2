    "MXC_I2C_Init / MXC_I2C_MasterWrite / MXC_I2C_MasterRead",
    "MXC_ADC_Init / MXC_ADC_StartConversion / MXC_ADC_GetData",
    "MXC_DMA_Init / MXC_DMA_AcquireChannel / MXC_DMA_Start",
    "MXC_RTC_Init / MXC_RTC_Start / MXC_RTC_GetTime",
    "MXC_TMR_Init / MXC_TMR_Start / MXC_TMR_Stop",
    "MXC_WDT_Init / MXC_WDT_Enable / MXC_WDT_Feed",
    "MXC_TRNG_Init / MXC_TRNG_Random",
    "MXC_LP_EnterSleepMode / MXC_LP_EnterDeepSleepMode",
    "MXC_ICC_Enable / MXC_ICC_Disable",
    "Board_Init (BSP weak function override)",
